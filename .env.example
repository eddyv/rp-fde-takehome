# Copy to .env and fill in your key. docker compose reads .env automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Anthropic-compat endpoint (e.g. Ollama). localhost works for the native
# `uv run` path; the Docker stack must reach the host instead:
# ANTHROPIC_BASE_URL=http://localhost:11434            # native
# ANTHROPIC_BASE_URL=http://host.docker.internal:11434 # docker compose
# CONFIDENCE_THRESHOLD=0.6
# BREAKER_THRESHOLD=25
# MAX_RETRY_PASSES=3
